{
  "manifest_version": 3,
  "name": "DataGambit",
  "version": "1.0.0",
  "description": "Opening recommendations for Lichess.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://lichess.org/*",
    "https://datagambit.onrender.com/*"
  ],
  "action": {
    "default_title": "DataGambit",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "DataGambiticon.png",
      "32": "DataGambiticon.png",
      "48": "DataGambiticon.png",
      "128": "DataGambiticon.png"
    }
  },
  "icons": {
    "16": "DataGambiticon.png",
    "32": "DataGambiticon.png",
    "48": "DataGambiticon.png",
    "128": "DataGambiticon.png"
  }
}
